# ── Fly.io production secrets ─────────────────────────────────────────────────
# Copy to .env.fly and fill in values, then run:
#   fly secrets import < .env.fly
# DO NOT commit .env.fly — it contains real credentials.

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase asyncpg via pooler (db.*.supabase.co non risolve per questo progetto — usare sempre il pooler)
DATABASE_URL=postgresql+asyncpg://postgres.izscgffubtakzvwxchqt:[YOUR_DB_PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# ── Supabase PostgREST (heartbeats, direct table writes) ─────────────────────
SUPABASE_URL=https://izscgffubtakzvwxchqt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=[YOUR_SERVICE_ROLE_KEY]

# ── Redis (Upstash — created via: fly ext upstash redis create) ───────────────
REDIS_URL=redis://default:[PASSWORD]@[HOST].upstash.io:6379

# ── Football data sources ─────────────────────────────────────────────────────
FOOTBALL_DATA_ORG_API_KEY=[KEY]
ODDS_API_KEY=[KEY]
RAPIDAPI_KEY=[KEY]

# ── Telegram (Telegram bot for Monitor agent alerts) ─────────────────────────
TELEGRAM_BOT_TOKEN=[TOKEN]
TELEGRAM_CHAT_ID=[CHAT_ID]

# ── Anthropic (AI analysis, optional) ────────────────────────────────────────
ANTHROPIC_API_KEY=[KEY]

# ── Dashboard URL (for heartbeat POST) ───────────────────────────────────────
DASHBOARD_URL=https://betredge-app.vercel.app
RESEARCH_SECRET=[SAME_AS_VERCEL_RESEARCH_SECRET]
ADMIN_SECRET=[VERCEL_ADMIN_PANEL_SECRET]

# ── Trading (keep paper=true on server for safety) ───────────────────────────
PAPER_TRADING=true
BANKROLL=10.0

# ── Ollama (disabled on server — no GPU) ─────────────────────────────────────
OLLAMA_BASE_URL=
