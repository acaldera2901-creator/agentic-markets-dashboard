# ─────────────────────────────────────────────────────────────────────────────
# AGENTIC MARKETS / BetRedge — Environment Variables (source of truth)
# Copy this file to .env and fill in real values before starting.
# NEVER commit .env to git. NEVER put real secrets in this file.
#
# This repo is a monorepo: the Python prediction pipeline (run.py, agents/, core/)
# AND the Next.js web app (app/, lib/, components/) share one .env.
#   • PART 1 — Shared infra + Python pipeline
#   • PART 2 — Next.js web app (BetRedge)  ← ~45 vars that were previously undocumented
# ─────────────────────────────────────────────────────────────────────────────


# ═════════════════════════════════════════════════════════════════════════════
# PART 1 — SHARED INFRA + PYTHON PREDICTION PIPELINE
# ═════════════════════════════════════════════════════════════════════════════

# ── Infrastructure ──────────────────────────────────────────────────────────
# Local dev: uses docker-compose defaults
# Docker: overridden automatically in docker-compose.yml
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql+asyncpg://agentic:password@localhost:5433/agentic_markets

# ── AI / LLM ────────────────────────────────────────────────────────────────
# Required for AnalystAgent + StrategistAgent LLM calls
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Ollama local model for ResearchAgent (fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Football / sports data APIs ──────────────────────────────────────────────
# API-Football (RapidAPI) — primary source for fixtures + settlement results.
# Used by both the Python pipeline and the Next.js settlement crons.
# Get from: https://rapidapi.com/api-sports/api/api-football
API_FOOTBALL_KEY=

# Football-Data.org — free tier for PL/SA/PD/BL1/FL1 (no daily cap)
# Get from: https://www.football-data.org/client/register
FOOTBALL_DATA_ORG_API_KEY=

# The Odds API — fallback odds source
# Get from: https://the-odds-api.com/
ODDS_API_KEY=

# ── Betfair Exchange ─────────────────────────────────────────────────────────
# Required for LIVE betting execution (not needed for paper trading)
# Italian accounts: authenticate via identitysso.betfair.it
# App Key: developer.betfair.com → My Applications → Create DELAY key
BETFAIR_APP_KEY=
BETFAIR_USERNAME=
BETFAIR_PASSWORD=

# ── Telegram bot (pipeline alerts) ───────────────────────────────────────────
# Required for bet alerts, settlement summaries, circuit breaker notifications
# 1. Create bot: https://t.me/BotFather → /newbot
# 2. Get CHAT_ID: start bot, then GET https://api.telegram.org/bot{TOKEN}/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Optional data APIs ───────────────────────────────────────────────────────
PINNACLE_API_KEY=
SBOBET_API_KEY=
OPENWEATHERMAP_API_KEY=
RAPIDAPI_KEY=
BALLDONTLIE_API_KEY=
PREDICTION_HUNT_API_KEY=
POLYMARKET_PRIVATE_KEY=

# ── Trading parameters ───────────────────────────────────────────────────────
# CRITICAL: set PAPER_TRADING=false only after 4-6 weeks of paper validation
PAPER_TRADING=true
# Starting bankroll in EUR
BANKROLL=500.0
# Kelly sizing — 0.25 = quarter-Kelly (conservative, recommended for live)
KELLY_FRACTION=0.25
# Hard cap per bet as % of bankroll (0.03 = max 3%)
MAX_BET_PCT=0.03
# Maximum total open exposure as fraction of bankroll
MAX_TOTAL_EXPOSURE=0.10
# Monthly drawdown limit — circuit breaker RED at this threshold
MAX_MONTHLY_DRAWDOWN=0.15

# ── Edge thresholds ──────────────────────────────────────────────────────────
MIN_EDGE=0.03
EDGE_MIN_SHARP=0.02
EDGE_MIN_SOFT=0.05

# ── Data-quality gates ───────────────────────────────────────────────────────
MAX_CONFIDENCE_INTERVAL_WIDTH=0.15
MIN_DATA_COMPLETENESS=0.75

# ── Pipeline alerts / timing ─────────────────────────────────────────────────
TELEGRAM_VALUE_EDGE_THRESHOLD=0.03
HEARTBEAT_INTERVAL=30
HEARTBEAT_TIMEOUT=60
DATA_REFRESH_INTERVAL=900
PREMATCH_REFRESH_INTERVAL=60


# ═════════════════════════════════════════════════════════════════════════════
# PART 2 — NEXT.JS WEB APP (BetRedge)
# Vars consumed by app/ · lib/ · components/. NEXT_PUBLIC_* are inlined into the
# client bundle at build time (never put secrets in a NEXT_PUBLIC_* var).
# ═════════════════════════════════════════════════════════════════════════════

# ── DB / Supabase (obbligatorie) ─────────────────────────────────────────────
# The web app reads/writes exclusively via the exec_sql RPC (SECURITY DEFINER,
# owner postgres) using the service-role key. The Python pipeline reuses
# SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY for its heartbeat write.
# Get from: Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── KV / Redis (Vercel KV or Upstash) ────────────────────────────────────────
# Serverless rate-limiting / cache. Auto-provisioned when the Vercel KV /
# Upstash integration is attached; leave blank locally to disable.
KV_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Pagamenti PayGate (obbligatorie per checkout) ────────────────────────────
# Card→USDC (Polygon) rail — the primary live checkout.
# PAYGATE_PAYOUT_WALLET: destination wallet that receives the settled USDC.
PAYGATE_PAYOUT_WALLET=0x0000000000000000000000000000000000000000
# Host della pagina hosted checkout (pay.php). Default checkout.paygate.to.
PAYGATE_CHECKOUT_HOST=paygate.to
# Host delle API di controllo (wallet.php / payment-status.php). Default api.paygate.to.
# Settare al Cloudflare worker white-label (es. api.betredge.com) per evitare il
# rate-limit per-IP di payment-status.php dal serverless. GATED: solo dopo conferma
# che il worker proxa /control/* (#PAYGATE-RATELIMIT-FIX).
PAYGATE_API_HOST=api.paygate.to
# Server-side test toggle (sandbox amounts). Keep false in prod.
PAYGATE_TEST_ENABLED=false
# Client flags: gate the checkout UI + surface the test badge.
NEXT_PUBLIC_PAYGATE_ENABLED=false
NEXT_PUBLIC_PAYGATE_TEST=false
# USDT TRC-20 address shown for manual crypto payment fallback (public, non-secret).
NEXT_PUBLIC_USDT_TRC20_ADDRESS=

# ── Stripe (rail dormiente) ──────────────────────────────────────────────────
# Subscriptions rail — coded but OFF until NEXT_PUBLIC_STRIPE_ENABLED=true.
# Get from: https://dashboard.stripe.com/apikeys (test keys for staging).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs for the Base / Premium plans (Stripe → Products).
STRIPE_PRICE_BASE=price_...
STRIPE_PRICE_PREMIUM=price_...
NEXT_PUBLIC_STRIPE_ENABLED=false

# ── PayPal / Apple Pay (rail dormiente) ──────────────────────────────────────
# One-click PayPal + Apple Pay rail — coded but OFF until wired.
# Get from: https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# "sandbox" | "live" — selects the PayPal API base URL.
PAYPAL_ENV=sandbox
# Webhook id for signature verification of PayPal webhooks.
PAYPAL_WEBHOOK_ID=
# Public client id for the PayPal JS SDK (inlined in the browser).
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# ── CRM / Resend (email) ─────────────────────────────────────────────────────
# Transactional + lifecycle email. CRM sends are opt-in and gated by CRM_SEND_ENABLED.
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
# Default "From" for CRM/marketing lifecycle mail (verified domain).
RESEND_FROM=BetRedge <noreply@betredge.com>
# Resend Audience id for the CRM segment sync.
RESEND_AUDIENCE_ID=
# Master switch for CRM lifecycle sends (false = compute segments, send 0 mail).
CRM_SEND_ENABLED=false
# HMAC secret for one-click unsubscribe links.
CRM_UNSUB_SECRET=
# "From" for the account-activation email (may differ from RESEND_FROM).
ACTIVATION_FROM=BetRedge <noreply@betredge.com>
# Require email activation before granting account access (auth flow).
AUTH_REQUIRE_EMAIL_ACTIVATION=false
# Reply-to / support address shown in account emails and pages.
ACCOUNT_CONTACT_EMAIL=support@betredge.com

# ── Cron / Admin secrets ─────────────────────────────────────────────────────
# Default-deny: an unset secret makes the guarded endpoint answer 401.
# Vercel cron auth — must match the value configured on Vercel (unset = crons
# 401 and the board goes stale silently).
CRON_SECRET=
# Admin panel password/secret. Required for /admin login and admin APIs.
ADMIN_SECRET=
# Founder/admin_full grant key for POST /api/founder/grant (default-deny).
FOUNDER_ACCESS_KEY=
# Bearer for the research/ML internal endpoints (Python pipeline ↔ web).
RESEARCH_SECRET=
# Server-side session signing secret (>=16 chars). Generate:
# node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=

# ── Company / legal (footer, invoices, legal pages) ──────────────────────────
# Valori correnti (interim "ponte Maven" 2026-07-13, da Registro commercio ZG/Zefix;
# post-costituzione SL ES: aggiornare qui + Vercel + ToS/Privacy/footer):
COMPANY_LEGAL_NAME=Maven Agency AG
COMPANY_VAT=CHE-193.960.193
COMPANY_ADDRESS=Blegistrasse 7, 6340 Baar (ZG), Switzerland
COMPANY_CONTACT_EMAIL=info@betredge.com

# ── Affiliate ("Piazza scommessa") sportsbook links ──────────────────────────
# Default OFF: feature inerte finché non viene accesa deliberatamente.
# Il flip a true / "*" richiede APPROVE umano su ch_deploy_gate (gate gambling).
SPORTSBOOK_LINKS_ENABLED=false
# CSV di country code ISO (es. "MT,CW") oppure "*" per globale. Vuoto = nessuno.
SPORTSBOOK_GEO_ALLOWLIST=
# Legacy single-affiliate config (bookmaker card + generic CTA).
AFFILIATE_URL=
AFFILIATE_BOOKMAKER=
AFFILIATE_BONUS=

# ── Site URLs ────────────────────────────────────────────────────────────────
# Canonical origin used to build absolute links (callbacks, emails, OG tags).
NEXT_PUBLIC_BASE_URL=https://betredge.com
NEXT_PUBLIC_SITE_URL=https://betredge.com
# Legacy dashboard URL (kept for pipeline links).
DASHBOARD_URL=

# ── Ops alerting (cron fail-loud) ────────────────────────────────────────────
# OPZIONALE. Se settata, i cron critici (settle, paygate-reconcile) POSTano un
# JSON {source, errors, ts} qui quando falliscono (incluso "tennis pipeline stale"
# = daemon Mac giù). Può puntare a QUALSIASI webhook: proxy Telegram sendMessage,
# Slack incoming webhook, Discord, endpoint custom. Vuoto = solo log su stderr
# (i run restano comunque 500 → Vercel li marca failed).
ALERT_WEBHOOK_URL=

# ── Live chat (Tawk.to) proxy ────────────────────────────────────────────────
# OPZIONALE. Vuoto = il widget carica diretto da embed.tawk.to (bloccato dalle
# VPN con anti-tracker). Settato (es. "chat.betredge.com") = il widget passa dal
# Cloudflare Worker servito dal nostro dominio → aggira il blocco.
# Vedi ops/OPS-TAWK-GOLIVE.md per i passi di deploy (lato Tommy).
NEXT_PUBLIC_TAWK_PROXY_HOST=

# ── Flag feature ─────────────────────────────────────────────────────────────
# New casual-first UX (design system + feed). false = classic UI.
NEXT_PUBLIC_UX_NEW=false
# Weekly Pick (multipla della casa, one-off). Inerte finché non è "true"; il flip
# richiede allineamento Michele + APPROVE ch_deploy_gate (tocca pagamenti/DB).
WEEKLY_PICK_ENABLED=false
# Launch promo (-50%). Server-side flag + deadline (ISO). The NEXT_PUBLIC_*
# counterparts drive the countdown UI in the browser.
LAUNCH_PROMO_ENABLED=false
LAUNCH_PROMO_DEADLINE=
NEXT_PUBLIC_LAUNCH_PROMO_ENABLED=false
NEXT_PUBLIC_LAUNCH_PROMO_DEADLINE=
# Tennis demo mode: serve synthetic tennis cards when live data is missing.
TENNIS_DEMO_MODE=false

# ── Vercel-injected (do NOT set manually) ────────────────────────────────────
# Populated automatically by Vercel at build/runtime; listed for reference only.
# NODE_ENV, VERCEL_URL, VERCEL_DEPLOYMENT_ID, VERCEL_GIT_COMMIT_SHA
